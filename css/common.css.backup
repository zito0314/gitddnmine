@import url("https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css");
@import url("https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap");

:root{
  --magenta-1:#fff0f6;
  --magenta-2:#ffd6e7;
  --magenta-3:#ffadd2;
  --magenta-4:#ff85c0;
  --magenta-5:#f759ab;
  --magenta-6:#eb2f96;
  --magenta-7:#c41d7f;
  --magenta-8:#9e1068;

  --primary:#eb2f96;
  --primary-hover:#f759ab;
  --primary-active:#c41d7f;
  --primary-bg:#fff0f6;
  --primary-bg-hover:#ffe0ef;
  --primary-border:#ffadd2;
  --primary-text:#c41d7f;

  --bg:#f5f5f5;
  --surface:#ffffff;
  --surface-soft:#fafafa;
  --line:#f0f0f0;
  --line-strong:#d9d9d9;
  --text:rgba(0,0,0,.88);
  --muted:rgba(0,0,0,.65);
  --subtle:rgba(0,0,0,.45);
  --blue:var(--primary);
  --blue-strong:var(--primary-active);
  --blue-soft:var(--primary-bg);
  --green:#52c41a;
  --green-soft:#f6ffed;
  --red:#ff4d4f;
  --red-soft:#fff2f0;
  --orange:#faad14;
  --orange-soft:#fffbe6;
  --dark:#ffffff;
  --dark-2:#fafafa;
  --shadow-sm:0 1px 2px 0 rgba(0,0,0,.03),0 1px 6px -1px rgba(0,0,0,.02),0 2px 4px 0 rgba(0,0,0,.02);
  --shadow-md:0 6px 16px 0 rgba(0,0,0,.08),0 3px 6px -4px rgba(0,0,0,.12),0 9px 28px 8px rgba(0,0,0,.05);
  --focus-ring:0 0 0 2px rgba(235,47,150,.12);
  --radius-sm:4px;
  --radius-md:8px;
  --radius-lg:12px;
}
*{box-sizing:border-box}
html,body{height:100%}
body{
  margin:0;
  background:var(--bg);
  color:var(--text);
  font-family:"Pretendard","SF Pro Text",-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Noto Sans KR",sans-serif;
  font-size:14px;
  line-height:22px;
  letter-spacing:-.01em;
  -webkit-font-smoothing:antialiased;
}
button,input,select,textarea{font-family:inherit}
button{cursor:pointer}
a{color:inherit;text-decoration:none}
